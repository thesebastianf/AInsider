# ═══════════════════════════════════════════════════════════════
# AInsider Tracker – Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────
POSTGRES_USER=ainsider
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ainsider

# ─── Application Settings ────────────────────────────────────
# Port to expose the web interface on
APP_PORT=4221

# (Note: Data Sources are configured via the UI or seed variables below)

# How often to fetch new trades (minutes)
SCHEDULER_INTERVAL_MINUTES=30

# How often to update stock prices (minutes)
PRICE_UPDATE_INTERVAL_MINUTES=15

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── LLM & Notification Providers ────────────────────────────
# Providers are configured via the Settings UI at runtime.
# However, you can OPTIONALLY pre-seed them using the variables below.
# If these are uncommented and provided, the app will automatically
# create and activate them on the very first start.

# -- Optional: Seed LLM Provider --
# SEED_LLM_PROVIDER=openai
# SEED_LLM_URL=https://api.openai.com
# SEED_LLM_MODEL=gpt-4o-mini
# SEED_LLM_API_KEY=sk-...

# -- Optional: Seed Notification Provider --
# SEED_NOTIFY_PROVIDER=telegram
# SEED_NOTIFY_CONFIG={"bot_token": "your-bot-token", "chat_id": "your-chat-id"}

# -- Optional: Seed Data Source Provider --
# If not provided, the system defaults to seeding House and Senate Stock Watcher providers.
# SEED_DATASOURCE_PROVIDER=quiver
# SEED_DATASOURCE_CONFIG={"api_key": "your-quiver-api-key"}
